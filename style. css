*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f4f4f4;
}

header{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

h1{
    font-size:55px;
    color:#0d6efd;
}

p{
    margin:20px 0;
    font-size:22px;
}

button{
    margin:10px;
    padding:15px 35px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    font-size:18px;
    background:#0d6efd;
    color:white;
}
